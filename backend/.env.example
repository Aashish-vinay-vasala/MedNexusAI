GROQ_API_KEY=your_groq_api_key_here

# Supabase — server-side only, never expose to frontend. Get from Project Settings → API Keys (legacy).
SUPABASE_URL=your_supabase_project_url
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Google Custom Search JSON API — powers the AI Assistant's web-search toggle. Free tier:
# 100 queries/day. Create an API key at console.cloud.google.com and a search engine at
# programmablesearchengine.google.com (enable "Search the entire web").
GOOGLE_CSE_API_KEY=your_google_custom_search_api_key
GOOGLE_CSE_CX=your_custom_search_engine_id
